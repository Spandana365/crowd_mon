*.pkl

# Keep the 4 model files the web app actually loads at runtime
!ui_handoff/models/crowd_prediction_model.joblib
!ui_handoff/models/label_encoders.joblib
!OMAN/checkpoints/student_best.pth
!OMAN/checkpoints/mobile_kd_stable/epoch_010.pth
# SENSE.pth (874 MB) and convnext (191 MB) are too large even for LFS — download manually

